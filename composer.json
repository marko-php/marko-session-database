{
    "name": "marko/session-database",
    "description": "Database session driver for Marko Framework",
    "type": "marko-module",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "marko/session": "self.version",
        "marko/database": "self.version"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Session\\Database\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Session\\Database\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
